{"type":"tool_use","timestamp":"2026-04-19T21:16:37.730Z","tool_name":"run_shell_command","tool_id":"run_shell_command_1776633397730_0","parameters":{"description":"Create src/experiment_1.py for logit landscape analysis.","command":"cat > src/experiment_1.py << 'EOF'\nimport torch\nimport torch.nn.functional as F\nfrom transformer_lens import HookedTransformer\nfrom sae_lens import SAE\nimport matplotlib.pyplot as plt\nimport numpy as np\nfrom tqdm import tqdm\nfrom utils import get_activations, interpolate, get_logits, get_sae_info\n\n# Configuration\nMODEL_NAME = \"gpt2-small\"\n# Choose a middle layer (e.g., 6) where semantic features are often found\nLAYER = 6\n# GPT-2 Small has d_model = 768\nD_MODEL = 768\n\n# Load model\nmodel = HookedTransformer.from_pretrained(MODEL_NAME)\n\n# Define Concept Pairs\n# (Prompt, Target Token to monitor)\nconcept_pairs = [\n    # 1. Congruent (Geographical)\n    (\"The capital of France is\", \" Paris\", \" Lyon\"),\n    # 2. Incongruent (Exclusive)\n    (\"The capital of France is\", \" Paris\", \" London\"),\n    # 3. Incongruent (Unrelated)\n    (\"The word is\", \" Paris\", \" justice\")\n]\n\n# For each pair, we'll extract activations for \" Paris\" (v1) and \" Lyon/London/justice\" (v2)\n# But wait, to get the activation for \" Paris\", the model should HAVE \" Paris\" as the token.\n# So we'll use prompts that end with the target token.\n\ndef get_concept_vector(model, text, layer):\n    \"\"\"Extract activation at the last token of text.\"\"\"\n    # We want the residual stream at the last token.\n    # pos=-1 means the last token in the sequence.\n    # If text is \"The capital of France is Paris\", \n    # the last token is \" Paris\".\n    activations = get_activations(model, text, layer, pos=-1)\n    return activations\n\n# Results storage\nresults = {}\n\nfor name, prompt_prefix, target1, target2 in [\n    (\"Congruent (Paris-Lyon)\", \"The city of\", \" Paris\", \" Lyon\"),\n    (\"Exclusive (Paris-London)\", \"The capital of France is\", \" Paris\", \" London\"),\n    (\"Unrelated (Paris-Justice)\", \"\", \" Paris\", \" justice\")\n]:\n    print(f\"\\nProcessing {name}...\")\n    \n    # Text sequences\n    text1 = f\"{prompt_prefix}{target1}\"\n    text2 = f\"{prompt_prefix}{target2}\"\n    \n    # Tokenize to check if target tokens are what we expect\n    tok1 = model.to_str_tokens(text1)[-1]\n    tok2 = model.to_str_tokens(text2)[-1]\n    print(f\"Target tokens: '{tok1}' vs '{tok2}'\")\n    \n    v1 = get_concept_vector(model, text1, LAYER)\n    v2 = get_concept_vector(model, text2, LAYER)\n    \n    # Interpolate\n    v_interp, alphas = interpolate(v1, v2, steps=11)\n    \n    # Get Logits\n    logits = get_logits(model, v_interp) # [steps, vocab_size]\n    probs = F.softmax(logits, dim=-1)\n    \n    # Monitor probabilities of target tokens\n    idx1 = model.to_single_token(target1)\n    idx2 = model.to_single_token(target2)\n    \n    p1 = probs[:, idx1].detach().cpu().numpy()\n    p2 = probs[:, idx2].detach().cpu().numpy()\n    \n    # Entropy\n    entropy = - (probs * torch.log(probs + 1e-10)).sum(dim=-1).detach().cpu().numpy()\n    \n    results[name] = {\n        'alphas': alphas,\n        'p1': p1,\n        'p2': p2,\n        'entropy': entropy,\n        'target1': target1,\n        'target2': target2\n    }\n\n# Visualization\nplt.figure(figsize=(15, 5))\n\nfor i, (name, data) in enumerate(results.items()):\n    plt.subplot(1, 3, i+1)\n    plt.plot(data['alphas'], data['p1'], label=f\"Prob({data['target1']})\", marker='o')\n    plt.plot(data['alphas'], data['p2'], label=f\"Prob({data['target2']})\", marker='x')\n    plt.title(name)\n    plt.xlabel(\"Interpolation Alpha\")\n    plt.ylabel(\"Probability\")\n    plt.legend()\n    plt.grid(True)\n\nplt.tight_layout()\nplt.savefig(\"results/logit_landscape.png\")\nprint(\"\\nLogit landscape plot saved to results/logit_landscape.png\")\n\n# Now check SAE (if we can find one)\n# GPT-2 Small Layer 6 SAE\ntry:\n    from